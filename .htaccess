Options -Indexes

<IfModule mod_rewrite.c>
	RewriteEngine On
	RewriteBase /rare-stone/

	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^ index.php [L,QSA]
</IfModule>

<FilesMatch "^(\.env|setup_db\.php|composer\.json|composer\.lock)$">
	Require all denied
</FilesMatch>
